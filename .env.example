# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MARKUP_PCT=0.03
MAX_NEGOTIATION_ROUNDS=3

# ── Anthropic — AI-powered supplier response parsing ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Path to OAuth2 credentials JSON file, or inline JSON string
GMAIL_CREDENTIALS=/path/to/gmail_credentials.json
GMAIL_SENDER=your@email.com

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Airtable — Supplier DB & RFQ state ───────────────────────────────────────
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# ── FX rates ──────────────────────────────────────────────────────────────────
FX_CACHE_TTL=3600  # seconds
